{
  "info": {
    "name": "Content Broadcasting System",
    "_postman_id": "d4d42663-c447-4dff-bb98-4f0a7b624001",
    "description": "Postman collection for the Content Broadcasting System backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "teacherToken", "value": "" },
    { "key": "principalToken", "value": "" },
    { "key": "teacherId", "value": "replace-with-teacher-id" },
    { "key": "contentId", "value": "replace-with-content-id" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Teacher",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teacher Two\",\n  \"email\": \"teacher2@school.edu\",\n  \"password\": \"Teacher@123\",\n  \"confirmPassword\": \"Teacher@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login Teacher",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher1@school.edu\",\n  \"password\": \"Teacher@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Principal",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"principal@school.edu\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Teacher Content",
      "item": [
        {
          "name": "Upload Content",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Maths Worksheet A", "type": "text" },
                { "key": "subject", "value": "maths", "type": "text" },
                { "key": "description", "value": "Chapter 1 worksheet", "type": "text" },
                { "key": "startTime", "value": "2026-06-01T08:00:00.000Z", "type": "text" },
                { "key": "endTime", "value": "2026-06-01T18:00:00.000Z", "type": "text" },
                { "key": "rotationDuration", "value": "5", "type": "text" },
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/content"
          }
        },
        {
          "name": "List My Content",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacherToken}}" }],
            "url": "{{baseUrl}}/api/content/mine?page=1&limit=10"
          }
        }
      ]
    },
    {
      "name": "Principal Moderation",
      "item": [
        {
          "name": "List All Content",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{principalToken}}" }],
            "url": "{{baseUrl}}/api/content?page=1&limit=10"
          }
        },
        {
          "name": "List Pending Content",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{principalToken}}" }],
            "url": "{{baseUrl}}/api/approval/pending"
          }
        },
        {
          "name": "Approve Content",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{principalToken}}" }],
            "url": "{{baseUrl}}/api/approval/{{contentId}}/approve"
          }
        },
        {
          "name": "Reject Content",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{principalToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Image quality is too low\"\n}"
            },
            "url": "{{baseUrl}}/api/approval/{{contentId}}/reject"
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Subject Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{principalToken}}" }],
            "url": "{{baseUrl}}/api/analytics/subjects"
          }
        },
        {
          "name": "Most Active Subject",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{principalToken}}" }],
            "url": "{{baseUrl}}/api/analytics/subjects/most-active"
          }
        },
        {
          "name": "Teacher Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{principalToken}}" }],
            "url": "{{baseUrl}}/api/analytics/teachers"
          }
        }
      ]
    },
    {
      "name": "Public Broadcasting",
      "item": [
        {
          "name": "Live Content by Teacher",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/content/live/{{teacherId}}"
          }
        },
        {
          "name": "Live Content by Teacher + Subject",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/content/live/{{teacherId}}?subject=maths"
          }
        }
      ]
    }
  ]
}

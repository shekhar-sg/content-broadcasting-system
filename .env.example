# Server
PORT=3000
NODE_ENV=development

# PostgreSQL / Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/content_broadcasting

# JWT
JWT_SECRET=jwt_secret_key
JWT_EXPIRES_IN=7d

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Redis
REDIS_URL=redis://localhost:6379

# Seeded principal
PRINCIPAL_NAME='Principal Admin'
PRINCIPAL_EMAIL=principal@school.edu
PRINCIPAL_PASSWORD=Admin@1234

# Seeded demo teacher
DEMO_TEACHER_NAME='Demo Teacher'
DEMO_TEACHER_EMAIL=teacher1@school.edu
DEMO_TEACHER_PASSWORD=Teacher@123
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PRINCIPAL
  TEACHER
}

enum ContentStatus {
  PENDING
  Approved
  Rejected
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(TEACHER)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt

  uploadedContent Content[]     @relation("ContentUploader")
  approvedContent Content[]     @relation("ContentApprover")
  contentSlots    ContentSlot[]

  @@map("users")
}

model Content {
  id               String        @id @default(uuid())
  title            String
  description      String?
  subject          String
  filePath         String        @map("file_path")
  fileType         String        @map("file_type")
  fileSize         Int           @map("file_size")
  uploadedBy       String        @map("uploaded_by")
  status           ContentStatus @default(PENDING)
  rejectionReason  String?       @map("rejection_reason")
  approvedBy       String?       @map("approved_by")
  approvedAt       DateTime?     @map("approved_at") @db.Timestamptz
  startTime        DateTime?     @map("start_time") @db.Timestamptz
  endTime          DateTime?     @map("end_time") @db.Timestamptz
  rotationDuration Int           @default(5) @map("rotation_duration")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz

  uploader       User              @relation("ContentUploader", fields: [uploadedBy], references: [id])
  approver       User?             @relation("ContentApprover", fields: [approvedBy], references: [id])
  contentSchdule ContentSchedule[]

  @@index([uploadedBy, status])
  @@index([subject, status])
  @@map("content")
}

model ContentSlot {
  id        String   @id @default(uuid())
  teacherId String   @map("teacher_id")
  subject   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  teacher   User              @relation(fields: [teacherId], references: [id])
  schedules ContentSchedule[]

  @@unique([teacherId, subject])
  @@map("content_slots")
}

model ContentSchedule {
  id            String   @id @default(uuid())
  contentId     String   @unique @map("content_id")
  slotId        String   @map("slot_id")
  rotationOrder Int      @map("rotation_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  content Content      @relation(fields: [contentId], references: [id])
  slot    ContentSlot? @relation(fields: [slotId], references: [id])

  @@unique([slotId, rotationOrder])
  @@map("content_schedule")
}
